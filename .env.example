# Portfolio Environment Variables Template
# Copy this file to .env and fill in the values

# Google Analytics 4
VITE_GA_ID=G-XXXXXXXXXX
VITE_GA_DEBUG=false

# IndexNow Configuration
VITE_INDEXNOW_KEY=your_indexnow_api_key_here
VITE_SITE_HOST=anuragtripathi.pro
VITE_SITE_URL=https://anuragtripathi.pro

# NVIDIA AI Service (Backend Function only - DO NOT add VITE_ prefix)
# This should ONLY be set in the Netlify Dashboard, not committed to code.
NVIDIA_API_KEY=your_nvidia_api_key_here
